      "causes": ["Surcharge mécanique", "Accélération trop rapide", "Moteur inadapté au variateur", "Refroidissement variateur insuffisant"],
      "verifications": ["Lire courant de sortie vs nominal", "Vérifier paramètres acc/dec et limite courant", "Contrôler ventilateur variateur", "Mesurer température dissipateur"],
