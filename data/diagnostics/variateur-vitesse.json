    "r_ok": {
      "type": "result",
      "text": "Variateur opérationnel",
      "severity": "success",
      "causes": [],
      "verifications": ["Sauvegarder paramètres variateur", "Noter courants et températures de référence"],
      "actions": ["Planifier nettoyage filtres variateur", "Vérifier serrage borniers annuellement"]
