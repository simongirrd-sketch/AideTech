      "causes": ["Perte bus Modbus/Profibus/Ethernet", "Paramètres réseau incorrects", "Câble communication défectueux", "Adresse esclave en conflit"],
      "verifications": ["Contrôler LED communication", "Vérifier adresse et baudrate", "Tester câble et terminaison bus", "Consulter manuel code défaut exact"],
      "actions": ["Reconfigurer paramètres communication", "Remplacer câble bus", "Reset usine si corruption paramètres", "Mettre à jour firmware si bug connu"]
    },
    "r_sortie": {
      "type": "result",
      "text": "Pas de rotation malgré consigne",
      "severity": "warning",
