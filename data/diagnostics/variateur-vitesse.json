{
  "id": "variateur-vitesse",
  "title": "Diagnostic variateur de vitesse",
  "description": "Arbre de décision variateur industriel",
  "category": "automatisme",
  "startNode": "q_alim",
  "nodes": {
    "q_alim": {
      "type": "question",
      "text": "Le variateur est-il alimenté (LED réseau allumée) ?",
      "options": [
        { "label": "Oui", "next": "q_defaut" },
        { "label": "Non", "next": "r_pas_alim" }
      ]
    },
    "q_defaut": {
      "type": "question",
      "text": "Un code défaut s'affiche sur l'écran ou clignote une LED rouge ?",
      "options": [
        { "label": "Oui, code défaut visible", "next": "q_surcharge" },
        { "label": "Non, pas de défaut affiché", "next": "q_moteur_tourne" }
      ]
    },
    "q_surcharge": {
      "type": "question",
      "text": "Le code défaut indique-t-il une surcharge (OC, OL, OH) ?",
      "options": [
        { "label": "Oui — surintensité / surchauffe", "next": "r_surcharge" },
        { "label": "Non — autre code (comm, bus, etc.)", "next": "r_comm" }
      ]
    },
    "q_moteur_tourne": {
      "type": "question",
      "text": "Le moteur tourne-t-il quand une consigne de vitesse est envoyée ?",
      "options": [
        { "label": "Oui mais vitesse instable", "next": "r_reglage" },
        { "label": "Non, moteur immobile", "next": "r_sortie" },
        { "label": "Oui, fonctionnement normal", "next": "r_ok" }
      ]
    },
    "r_pas_alim": {
